{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    }
  ],
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": { "includeFiles": "requirements.txt" }
    },
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ]
}